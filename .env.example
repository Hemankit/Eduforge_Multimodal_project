# LLM Provider Configuration
# Copy this file to .env and configure your setup

# ==================================================
# PROVIDER SELECTION (choose one)
# ==================================================

# Option 1: Local Mistral 7B (FREE, requires GPU)
# - No API key needed
# - Runs on your hardware
# - Good for development and testing
LLM_PROVIDER=local

# Option 2: Together AI Llama 3.3 70B (PAID API)
# - Requires API key (get from https://api.together.xyz/)
# - Cloud-hosted, no GPU needed
# - Better quality, 128K context window
# LLM_PROVIDER=together
# TOGETHER_API_KEY=your_together_api_key_here

# ==================================================
# NOTES
# ==================================================
# - Default is "local" (Mistral 7B)
# - Together AI pricing: ~$0.88 per 1M tokens
# - Free tier: $25 credit at signup
# - System automatically falls back to local if API fails
